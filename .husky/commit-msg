#!/bin/bash

MSG=$(cat "$1")

# Only check publish commits
if echo "$MSG" | grep -qi "publish"; then
  # Extract version
  VERSION=$(echo "$MSG" | grep -oP 'v\d+\.\d+\.\d+')

  if [ -z "$VERSION" ]; then
    echo ""
    echo "⚠ Publish commit detected but no version found (expected vN.N.N)"
    echo "  Example: chore: publish v0.5.0 — description"
    echo ""
    exit 1
  fi

  # If no [Unreleased] section exists, generate one from commits
  if ! grep -qE "\[Unreleased\]|\[$VERSION\]" CHANGELOG.md 2>/dev/null; then
    echo "⚙ No [Unreleased] section found — generating from git log..."

    # Generate changelog and prepend to CHANGELOG.md
    GENERATED=$(./scripts/generate-changelog.sh 2>/dev/null)
    if [ -n "$GENERATED" ]; then
      # Insert after the header (line 5, after the format/versioning lines)
      HEADER=$(head -6 CHANGELOG.md)
      BODY=$(tail -n +7 CHANGELOG.md)
      {
        echo "$HEADER"
        echo ""
        echo "$GENERATED"
        echo "$BODY"
      } > CHANGELOG.md.tmp
      mv CHANGELOG.md.tmp CHANGELOG.md
      echo "✓ Generated changelog from git commits"
    fi
  fi

  # Rename [Unreleased] to the version with today's date
  if grep -q "\[Unreleased\]" CHANGELOG.md; then
    DATE=$(date +%Y-%m-%d)
    sed -i "s/## \[Unreleased\]/## [$VERSION] - $DATE/" CHANGELOG.md
    git add CHANGELOG.md
    echo "✓ CHANGELOG.md: [Unreleased] → [$VERSION] - $DATE"
  elif grep -q "\[$VERSION\]" CHANGELOG.md; then
    git add CHANGELOG.md
    echo "✓ CHANGELOG.md already has [$VERSION]"
  fi
fi

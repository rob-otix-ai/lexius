{
  "name": "@robotixai/lexius-cli",
  "version": "0.1.1",
  "description": "CLI for Lexius AI compliance platform — classify systems, check obligations, calculate penalties, run assessments",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-otix-ai/lexius.git",
    "directory": "packages/cli"
  },
  "bin": {
    "lexius": "dist/bundle.cjs"
  },
  "files": [
    "dist/bundle.cjs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --external:pg-native --external:better-sqlite3 --external:pino-pretty --external:pino",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "@lexius/core": "workspace:*",
    "@lexius/infra": "workspace:*",
    "@lexius/logger": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}

FROM pgvector/pgvector:pg16

# Copy seed SQL init scripts (generated by drizzle migrations)
COPY src/migrations/ /docker-entrypoint-initdb.d/migrations/

# Copy a bootstrap script that runs migrations in order
COPY docker-entrypoint-initdb.d/ /docker-entrypoint-initdb.d/

ENV POSTGRES_DB=legal_ai
ENV POSTGRES_USER=legal_ai

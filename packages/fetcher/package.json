{
  "name": "@robotixai/lexius-fetcher",
  "version": "0.1.0",
  "description": "EUR-Lex CELLAR regulation fetcher + deterministic extractor for Lexius",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-otix-ai/lexius.git",
    "directory": "packages/fetcher"
  },
  "bin": {
    "lexius-fetch": "dist/bundle.cjs"
  },
  "files": ["dist/bundle.cjs", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc && esbuild dist/cli.js --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --external:pg-native --external:better-sqlite3 --define:process.env.NODE_ENV='\"production\"'",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@lexius/db": "workspace:*",
    "@lexius/infra": "workspace:*",
    "@lexius/logger": "workspace:*",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "drizzle-orm": "^0.35.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^1.6.0"
  }
}

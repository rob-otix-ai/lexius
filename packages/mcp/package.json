{
  "name": "@robotixai/lexius-mcp",
  "version": "0.1.2",
  "description": "MCP server for Lexius compliance platform — stdio and HTTP transports",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./lib": "./dist/lib.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-otix-ai/lexius.git",
    "directory": "packages/mcp"
  },
  "bin": {
    "lexius-mcp": "dist/bundle.cjs"
  },
  "files": [
    "dist/bundle.cjs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --external:pg-native --external:better-sqlite3 --external:pino-pretty --external:pino",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "@lexius/core": "workspace:*",
    "@lexius/db": "workspace:*",
    "@lexius/infra": "workspace:*",
    "@lexius/logger": "workspace:*",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/express": "^5.0.2"
  }
}

{
  "name": "@robotixai/lexius-api",
  "version": "0.3.0",
  "description": "REST API + SSE MCP server for Lexius AI compliance platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-otix-ai/lexius.git",
    "directory": "packages/api"
  },
  "bin": {
    "lexius-api": "dist/bundle.cjs"
  },
  "files": [
    "dist/bundle.cjs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --external:pg-native --external:better-sqlite3 --define:process.env.NODE_ENV='\"production\"'",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.21.0",
    "zod": "^3.23.0",
    "cors": "^2.8.5",
    "@lexius/core": "workspace:*",
    "@lexius/db": "workspace:*",
    "@lexius/infra": "workspace:*",
    "@robotixai/lexius-agent": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "drizzle-orm": "^0.35.0",
    "@lexius/logger": "workspace:*",
    "pino-http": "^10.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.1.0"
  }
}
